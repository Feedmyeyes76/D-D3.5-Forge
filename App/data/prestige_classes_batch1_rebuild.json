      {
        "id": "assassin.death_attack",
        "name": "Death Attack",
        "type": "ability",
        "description": {
          "summary": "Study a victim, then make a sneak attack that can kill or paralyze.",
          "fullText": "If the assassin studies a victim for 3 rounds and then makes a sneak attack with a melee weapon that successfully deals damage, the sneak attack has the additional effect of possibly either paralyzing or killing the target. The target receives a Fortitude save against DC 10 + assassin level + the assassin's Intelligence modifier. The assassin must make the attack within 3 rounds after study is complete. Paralysis lasts 1d6 rounds plus 1 round per assassin level."
        },
        "progression": {
          "1": {
            "mechanics": {
              "requiresStudyRounds": 3,
              "attackWindowRounds": 3,
              "requiresMeleeSneakAttack": true,
              "saveType": "fortitude",
              "saveDcFormula": "10 + class level + Intelligence modifier",
              "effects": [
