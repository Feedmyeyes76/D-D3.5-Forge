    "classFeatures": [
      "Skirmish (+1d6); trapfinding — Level 1",
      "Battle fortitude +1; uncanny dodge — Level 2",
      "Fast movement +10 ft.; skirmish (+1d6, +1 AC); trackless step — Level 3",
